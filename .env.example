# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=sqlite:///./teacher_bot.db
# For PostgreSQL: postgresql://user:password@localhost/teacher_bot

# Railway
RAILWAY_PORT=8000
WEBHOOK_URL=your_railway_app_url_here/webhook

# Environment
ENVIRONMENT=development
DEBUG=True

# Logging
LOG_LEVEL=INFO
